# ── Server ─────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Neon PostgreSQL ─────────────────────────────
# Get this from your Neon dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/lmsdb?sslmode=require

# ── JWT ─────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_32chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (BullMQ) ──────────────────────────────
REDIS_URL=redis://localhost:6379

# ── GitHub Webhooks ─────────────────────────────
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# ── File Uploads (Cloudinary or S3) ────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Frontend ────────────────────────────────────
FRONTEND_URL=http://localhost:3000
